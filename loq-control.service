[Unit]
Description=LOQ Control Daemon — Advanced Hardware Orchestration
After=multi-user.target
StartLimitIntervalSec=0

[Service]
Type=notify
ExecStart=/usr/bin/python3 -m loq_control.services.daemon
Restart=always
RestartSec=5
# Enable the hardware watchdog
WatchdogSec=10
# Allow the daemon to notify systemd it's alive
NotifyAccess=all

[Install]
WantedBy=multi-user.target
